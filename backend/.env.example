PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/homedecor
CLIENT_URL=http://localhost:3000

# Comma-separated list - each of these is auto-promoted to "admin" the
# first time that email signs in. Add more any time, no restart needed
# beyond the normal server restart to pick up the new .env value.
ADMIN_EMAILS=robiulhasanjisan88@gmail.com,decorixstudiobd@gmail.com

# Firebase Admin SDK (download service account JSON from Firebase console
# Project Settings > Service Accounts > Generate new private key)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
